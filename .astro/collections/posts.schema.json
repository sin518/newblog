{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "categories": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "heroImage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "string"
        }
      ]
    },
    "heroImageAlt": {
      "type": "string"
    },
    "showFeaturedImage": {
      "type": "boolean"
    },
    "dynamicPostCardHeight": {
      "type": "boolean"
    },
    "canonicalURL": {
      "type": "string",
      "format": "uri"
    },
    "comments": {
      "type": "boolean"
    },
    "toc": {
      "default": true,
      "type": "boolean"
    },
    "pinned": {
      "default": false,
      "type": "boolean"
    },
    "math": {
      "default": false,
      "type": "boolean"
    },
    "lang": {
      "type": "string",
      "enum": [
        "zh",
        "en"
      ]
    },
    "translationKey": {
      "type": "string"
    },
    "unlisted": {
      "default": false,
      "type": "boolean"
    },
    "unlistedHideFromSeo": {
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate"
  ]
}